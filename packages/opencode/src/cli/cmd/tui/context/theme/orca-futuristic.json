{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bgDark": "#0A0A0A",
    "bgPanel": "#11100E",
    "bgCard": "#171512",
    "bgHover": "#211D18",
    "primaryMain": "#E39A59",
    "primaryLight": "#F2B174",
    "primaryDark": "#B8743F",
    "accent": "#E39A59",
    "accentGlow": "#F5C08A",
    "statusIdle": "#8C7E71",
    "statusActive": "#E39A59",
    "statusThinking": "#D88945",
    "statusSuccess": "#72C98B",
    "statusWarning": "#DDA160",
    "statusError": "#D5694A",
    "textPrimary": "#F1ECE6",
    "textSecondary": "#B8ADA0",
    "textMuted": "#8F8173",
    "borderDefault": "#4B433B",
    "borderFocus": "#E39A59",
    "borderGlow": "#D1894C"
  },
  "theme": {
    "primary": {
      "dark": "primaryMain",
      "light": "primaryMain"
    },
    "secondary": {
      "dark": "bgCard",
      "light": "bgPanel"
    },
    "accent": {
      "dark": "accent",
      "light": "accent"
    },
    "error": {
      "dark": "statusError",
      "light": "statusError"
    },
    "warning": {
      "dark": "statusWarning",
      "light": "statusWarning"
    },
    "success": {
      "dark": "statusSuccess",
      "light": "statusSuccess"
    },
    "info": {
      "dark": "primaryLight",
      "light": "primaryLight"
    },
    "text": {
      "dark": "textPrimary",
      "light": "#1A1A1A"
    },
    "textMuted": {
      "dark": "textMuted",
      "light": "#8F8173"
    },
    "background": {
      "dark": "bgDark",
      "light": "#FFFFFF"
    },
    "backgroundPanel": {
      "dark": "bgPanel",
      "light": "#F5F5F5"
    },
    "backgroundElement": {
      "dark": "bgCard",
      "light": "#E0E0E0"
    },
    "backgroundMenu": {
      "dark": "bgHover",
      "light": "#E0E0E0"
    },
    "selectedListItemText": {
      "dark": "bgDark",
      "light": "#FFFFFF"
    },
    "border": {
      "dark": "borderDefault",
      "light": "#CCCCCC"
    },
    "borderActive": {
      "dark": "borderFocus",
      "light": "primaryMain"
    },
    "borderSubtle": {
      "dark": "#3A342D",
      "light": "#B0B0B0"
    },
    "diffAdded": {
      "dark": "statusSuccess",
      "light": "#00CC55"
    },
    "diffRemoved": {
      "dark": "statusError",
      "light": "#CC2900"
    },
    "diffContext": {
      "dark": "textSecondary",
      "light": "#8F8173"
    },
    "diffHunkHeader": {
      "dark": "textMuted",
      "light": "#B0B0B0"
    },
    "diffHighlightAdded": {
      "dark": "#00FF88",
      "light": "#00AA44"
    },
    "diffHighlightRemoved": {
      "dark": "#FF5533",
      "light": "#AA2200"
    },
    "diffAddedBg": {
      "dark": "#142218",
      "light": "#E6FFF2"
    },
    "diffRemovedBg": {
      "dark": "#2A1814",
      "light": "#FFE6E6"
    },
    "diffContextBg": {
      "dark": "bgPanel",
      "light": "#F0F0F0"
    },
    "diffLineNumber": {
      "dark": "textMuted",
      "light": "#E0E0E0"
    },
    "diffAddedLineNumberBg": {
      "dark": "#002613",
      "light": "#CCFFEA"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#260800",
      "light": "#FFCCCC"
    },
    "markdownText": {
      "dark": "textPrimary",
      "light": "#1A1A1A"
    },
    "markdownHeading": {
      "dark": "primaryMain",
      "light": "primaryMain"
    },
    "markdownLink": {
      "dark": "primaryLight",
      "light": "primaryMain"
    },
    "markdownLinkText": {
      "dark": "primaryLight",
      "light": "primaryLight"
    },
    "markdownCode": {
      "dark": "statusSuccess",
      "light": "#008844"
    },
    "markdownBlockQuote": {
      "dark": "textMuted",
      "light": "#8F8173"
    },
    "markdownEmph": {
      "dark": "statusWarning",
      "light": "#CC9900"
    },
    "markdownStrong": {
      "dark": "primaryMain",
      "light": "primaryMain"
    },
    "markdownHorizontalRule": {
      "dark": "borderDefault",
      "light": "#CCCCCC"
    },
    "markdownListItem": {
      "dark": "primaryLight",
      "light": "primaryMain"
    },
    "markdownListEnumeration": {
      "dark": "primaryLight",
      "light": "primaryLight"
    },
    "markdownImage": {
      "dark": "primaryLight",
      "light": "primaryMain"
    },
    "markdownImageText": {
      "dark": "primaryLight",
      "light": "primaryLight"
    },
    "markdownCodeBlock": {
      "dark": "textPrimary",
      "light": "#1A1A1A"
    },
    "syntaxComment": {
      "dark": "textMuted",
      "light": "#8F8173"
    },
    "syntaxKeyword": {
      "dark": "primaryMain",
      "light": "primaryMain"
    },
    "syntaxFunction": {
      "dark": "primaryLight",
      "light": "#CC5500"
    },
    "syntaxVariable": {
      "dark": "statusWarning",
      "light": "#CC9900"
    },
    "syntaxString": {
      "dark": "statusSuccess",
      "light": "#008844"
    },
    "syntaxNumber": {
      "dark": "statusWarning",
      "light": "#CC9900"
    },
    "syntaxType": {
      "dark": "primaryLight",
      "light": "#CC5500"
    },
    "syntaxOperator": {
      "dark": "primaryMain",
      "light": "primaryMain"
    },
    "syntaxPunctuation": {
      "dark": "textSecondary",
      "light": "#8F8173"
    }
  }
}
